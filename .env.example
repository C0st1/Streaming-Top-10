# ============================================================
# Environment Configuration — Netflix Top 10 Stremio Addon
# ============================================================
# Copy this file to .env and fill in values as needed.

# ENCRYPTION KEY (REQUIRED for v3.7.0+)
# This key is used to encrypt the configuration tokens.
# Generate a secure random string (at least 32 characters).
# You can generate one with: openssl rand -base64 32
# IMPORTANT: Keep this secret! If changed, existing tokens will stop working.
ENCRYPTION_KEY=your-secure-encryption-key-here-change-me

# TMDB API Key (optional server-side default — users can provide their own)
# TMDB_API_KEY=

# Cache TTL in milliseconds (default: 3600000 = 1 hour)
# CACHE_TTL=3600000

# TMDB match cache TTL in milliseconds (default: 21600000 = 6 hours)
# TMDB_MATCH_CACHE_TTL=21600000

# TMDB API request concurrency limit (default: 5)
# TMDB_CONCURRENCY=5

# FlixPatrol scrape timeout in milliseconds (default: 12000)
# FLIXPATROL_TIMEOUT=12000

# TMDB API timeout in milliseconds (default: 8000)
# TMDB_TIMEOUT=8000

# Max config tokens to store in memory (default: 5000)
# Note: Not used in v3.7.0+ as configs are stored in encrypted tokens
# CONFIG_STORE_MAX=5000

# Log level (default: info)
# Options: debug, info, warn, error
# LOG_LEVEL=info

# Node environment (production | development)
# NODE_ENV=production
